<FilesMatch "\.(json)$">
  Header set Content-Type "application/json; charset=UTF-8"
  Header set Access-Control-Allow-Origin "*"
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# Deny access to non-JSON files
<FilesMatch "(?<!\.json)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>
